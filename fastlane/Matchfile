# `match` stores signing certificates and provisioning profiles in a SEPARATE,
# PRIVATE git repo (encrypted). Create that repo and set its URL here.
# Docs: https://docs.fastlane.tools/actions/match/
git_url(ENV["MATCH_GIT_URL"] || "git@github.com:Tomisin-09/ore-ios-certificates.git")
storage_mode("git")
type("appstore")
app_identifier(["click.decooperations.ore"])
# username / team_id supplied via App Store Connect API key in CI.