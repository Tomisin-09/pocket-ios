# Xcode / generated project
Pocket.xcodeproj/
*.xcworkspace/
!default.xcworkspace
xcuserdata/
DerivedData/
build/
build-device/
*.xcuserstate
*.moved-aside

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods / Carthage (not used, but guard anyway)
Pods/
Carthage/Build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/
fastlane/README.md

# Signing — never commit certs/profiles or local team config
*.mobileprovision
*.p12
*.cer
*.certSigningRequest
*.local.xcconfig

# Secrets / env
.env
.env.*
*.secret

# Terraform
infrastructure/**/.terraform/
infrastructure/**/*.tfstate
infrastructure/**/*.tfstate.*
infrastructure/**/*.tfvars
!infrastructure/**/*.example.tfvars

# macOS
.DS_Store

# Local preview screenshots (not committed)
.preview/

# Third-party reference material — raw sources are reference-only, never
# committed or shipped. Our derivatives live in docs/research/ instead.
# Anchored to repo root so it does NOT match docs/research/.
/research/
